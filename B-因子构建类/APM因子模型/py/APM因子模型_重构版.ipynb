    "def calculate_apm_factor(stocks: List[str], benchmark: str, \n",
    "                        end_date: str, factor_type: str = 'apm_raw',\n",
    "                        lookback_days: int = 20) -> pd.Series:\n",
    "    \"\"\"计算APM因子的主函数\"\"\"\n",
    "    \n",
    "    calculator = APMFactorCalculator(data_provider)\n",
    "    \n",
    "    # 获取日内数据\n",
    "    print(\"正在获取日内数据...\")\n",
    "    data_dict = calculator.get_intraday_data(stocks, benchmark, end_date, lookback_days)\n",
    "    \n",
    "    if not data_dict:\n",
    "        print(\"未获取到有效数据\")\n",
    "        return pd.Series()\n",
    "    \n",
    "    # 定义因子类型对应的时段\n",
    "    factor_periods = {\n",
    "        'apm_raw': (calculator.TIME_PERIODS['上午'], calculator.TIME_PERIODS['下午']),\n",
    "        'apm_new': ('overnight', calculator.TIME_PERIODS['下午']),\n",
    "        'apm_1': ('overnight', calculator.TIME_PERIODS['pm1']),\n",
    "        'apm_2': (calculator.TIME_PERIODS['am1'], calculator.TIME_PERIODS['pm1']),\n",
    "        'apm_3': (calculator.TIME_PERIODS['am2'], calculator.TIME_PERIODS['pm2'])\n",
    "    }\n",
    "    \n",
    "    period1, period2 = factor_periods[factor_type]\n",
    "    \n",
    "    # 计算两个时段的收益率\n",
    "    print(f\"正在计算{factor_type}因子...\")\n",
    "    \n",
    "    if period1 == 'overnight':\n",
    "        am_returns = calculator.calculate_overnight_returns(data_dict)\n",
    "    else:\n",
    "        am_returns = calculator.calculate_period_returns(data_dict, period1[0], period1[1])\n",
    "    \n",
    "    pm_returns = calculator.calculate_period_returns(data_dict, period2[0], period2[1])\n",
    "    \n",
    "    if am_returns.empty or pm_returns.empty:\n",
    "        print(\"收益率计算失败\")\n",
    "        return pd.Series()\n",
    "    \n",
    "    # 计算回归残差\n",
    "    print(\"正在计算回归残差...\")\n",
    "    am_residuals = calculator.regression_residuals(am_returns.drop(columns=[benchmark], errors='ignore'), \n",
    "                                                  am_returns[benchmark])\n",
    "    pm_residuals = calculator.regression_residuals(pm_returns.drop(columns=[benchmark], errors='ignore'), \n",
    "                                                  pm_returns[benchmark])\n",
    "    \n",
    "    # 计算APM统计量\n",
    "    print(\"正在计算APM统计量...\")\n",
    "    apm_stats = calculator.calculate_apm_stat(am_residuals, pm_residuals)\n",
    "    \n",
    "    # 计算动量因子（过去20日收益率）\n",
    "    print(\"正在进行动量中性化...\")\n",
    "    momentum_returns = {}\n",
    "    for stock in stocks:\n",
    "        try:\n",
    "            df = data_provider.get_daily_data(stock, \n",
    "                                            (pd.to_datetime(end_date) - pd.Timedelta(days=40)).strftime('%Y%m%d'),\n",
    "                                            end_date)\n",
    "            if len(df) >= lookback_days:\n",
    "                returns = (df['close'].iloc[-1] / df['close'].iloc[-lookback_days-1]) - 1\n",
    "                momentum_returns[stock] = returns\n",
    "        except:\n",
    "            continue\n",
    "    \n",
    "    momentum_series = pd.Series(momentum_returns)\n",
    "    \n",
    "    # 动量中性化\n",
    "    final_factor = calculator.neutralize_momentum(apm_stats, momentum_series)\n",
    "    \n",
    "    print(f\"APM因子计算完成，共{len(final_factor)}只股票\")\n",
    "    return final_factor"
   ]
  },
