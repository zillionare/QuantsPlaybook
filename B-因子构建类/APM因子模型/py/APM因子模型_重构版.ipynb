    "class StockScreener:\n",
    "    \"\"\"股票筛选器，用于构建股票池\"\"\"\n",
    "    \n",
    "    def __init__(self, data_provider: TuShareDataProvider):\n",
    "        self.data_provider = data_provider\n",
    "    \n",
    "    def get_base_stock_pool(self, index_code: str = None, trade_date: str = None) -> List[str]:\n",
    "        \"\"\"获取基础股票池\"\"\"\n",
    "        if index_code and index_code != 'A':\n",
    "            # 获取指数成分股\n",
    "            return self.data_provider.get_index_stocks(index_code, trade_date)\n",
    "        else:\n",
    "            # 获取全部A股\n",
    "            df = self.data_provider.get_stock_list()\n",
    "            return df['ts_code'].tolist()\n",
    "    \n",
    "    def filter_suspended_stocks(self, stocks: List[str], \n",
    "                              end_date: str, \n",
    "                              lookback_days: int = 22,\n",
    "                              max_suspended_days: int = 21) -> List[str]:\n",
    "        \"\"\"过滤停牌股票\"\"\"\n",
    "        start_date = (pd.to_datetime(end_date) - pd.Timedelta(days=lookback_days*2)).strftime('%Y%m%d')\n",
    "        \n",
    "        valid_stocks = []\n",
    "        for stock in tqdm(stocks, desc='过滤停牌股票'):\n",
    "            try:\n",
    "                df = self.data_provider.get_daily_data(stock, start_date, end_date)\n",
    "                if len(df) >= lookback_days - max_suspended_days:\n",
    "                    valid_stocks.append(stock)\n",
    "            except:\n",
    "                continue\n",
    "            time.sleep(0.05)\n",
    "        \n",
    "        return valid_stocks\n",
    "    \n",
    "    def filter_st_stocks(self, stocks: List[str], trade_date: str = None) -> List[str]:\n",
    "        \"\"\"过滤ST股票\"\"\"\n",
    "        st_stocks = set(self.data_provider.get_st_stocks(trade_date))\n",
    "        return [stock for stock in stocks if stock not in st_stocks]\n",
    "    \n",
    "    def filter_new_stocks(self, stocks: List[str], \n",
    "                         trade_date: str, \n",
    "                         min_days: int = 180) -> List[str]:\n",
    "        \"\"\"过滤次新股\"\"\"\n",
    "        cutoff_date = (pd.to_datetime(trade_date) - pd.Timedelta(days=min_days)).strftime('%Y%m%d')\n",
    "        \n",
    "        valid_stocks = []\n",
    "        for stock in tqdm(stocks, desc='过滤次新股'):\n",
    "            try:\n",
    "                info = self.data_provider.get_stock_basic_info(stock)\n",
    "                if info and info.get('list_date', '99999999') <= cutoff_date:\n",
    "                    valid_stocks.append(stock)\n",
    "            except:\n",
    "                continue\n",
    "            time.sleep(0.05)\n",
    "        \n",
    "        return valid_stocks\n",
    "    \n",
    "    def get_filtered_stock_pool(self, index_code: str = '000905.XSHG', \n",
    "                               trade_date: str = None,\n",
    "                               filter_suspended: bool = True,\n",
    "                               filter_st: bool = True,\n",
    "                               filter_new: bool = True) -> List[str]:\n",
    "        \"\"\"获取经过筛选的股票池\"\"\"\n",
    "        if trade_date is None:\n",
    "            trade_date = dt.datetime.now().strftime('%Y%m%d')\n",
    "        \n",
    "        # 获取基础股票池\n",
    "        stocks = self.get_base_stock_pool(index_code, trade_date)\n",
    "        print(f\"基础股票池数量: {len(stocks)}\")\n",
    "        \n",
    "        # 过滤停牌股票\n",
    "        if filter_suspended:\n",
    "            stocks = self.filter_suspended_stocks(stocks, trade_date)\n",
    "            print(f\"过滤停牌后数量: {len(stocks)}\")\n",
    "        \n",
    "        # 过滤ST股票\n",
    "        if filter_st:\n",
    "            stocks = self.filter_st_stocks(stocks, trade_date)\n",
    "            print(f\"过滤ST后数量: {len(stocks)}\")\n",
    "        \n",
    "        # 过滤次新股\n",
    "        if filter_new:\n",
    "            stocks = self.filter_new_stocks(stocks, trade_date)\n",
    "            print(f\"过滤次新股后数量: {len(stocks)}\")\n",
    "        \n",
    "        return stocks\n",
    "\n",
    "# 初始化股票筛选器\n",
    "screener = StockScreener(data_provider)"
   ]
