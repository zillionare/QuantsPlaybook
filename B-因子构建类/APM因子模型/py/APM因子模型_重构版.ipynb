   "source": [
    "class APMFactorCalculator:\n",
    "    \"\"\"APM因子计算器\"\"\"\n",
    "    \n",
    "    # 定义时间段\n",
    "    TIME_PERIODS = {\n",
    "        '上午': ('09:30:00', '11:30:00'),\n",
    "        '下午': ('13:00:00', '15:00:00'),\n",
    "        'am1': ('09:30:00', '10:30:00'),\n",
    "        'am2': ('10:30:00', '11:30:00'),\n",
    "        'pm1': ('14:00:00', '15:00:00'),\n",
    "        'pm2': ('13:00:00', '14:00:00')\n",
    "    }\n",
    "    \n",
    "    def __init__(self, data_provider: TuShareDataProvider):\n",
    "        self.data_provider = data_provider\n",
    "    \n",
    "    def get_intraday_data(self, stocks: List[str], benchmark: str, \n",
    "                         end_date: str, lookback_days: int = 20) -> Dict[str, pd.DataFrame]:\n",
    "        \"\"\"获取日内数据\"\"\"\n",
    "        start_date = (pd.to_datetime(end_date) - pd.Timedelta(days=lookback_days*2)).strftime('%Y%m%d')\n",
    "        \n",
    "        all_codes = stocks + [benchmark]\n",
    "        data_dict = {}\n",
    "        \n",
    "        for code in tqdm(all_codes, desc='获取分钟数据'):\n",
    "            try:\n",
    "                df = self.data_provider.get_minute_data(code, start_date, end_date, '30min')\n",
    "                if not df.empty:\n",
    "                    df['trade_time'] = pd.to_datetime(df['trade_date'] + ' ' + df['trade_time'])\n",
    "                    df = df.set_index('trade_time').sort_index()\n",
    "                    data_dict[code] = df\n",
    "            except Exception as e:\n",
    "                print(f\"获取{code}数据失败: {e}\")\n",
    "                continue\n",
    "            time.sleep(0.1)\n",
    "        \n",
    "        return data_dict\n",
    "    \n",
    "    def calculate_period_returns(self, data_dict: Dict[str, pd.DataFrame], \n",
    "                               start_time: str, end_time: str) -> pd.DataFrame:\n",
    "        \"\"\"计算特定时段的收益率\"\"\"\n",
    "        returns_data = []\n",
    "        \n",
    "        for code, df in data_dict.items():\n",
    "            # 筛选时间段\n",
    "            mask = (df.index.time >= pd.to_datetime(start_time).time()) & \\\n",
    "                   (df.index.time <= pd.to_datetime(end_time).time())\n",
    "            period_data = df[mask]\n",
    "            \n",
    "            if len(period_data) == 0:\n",
    "                continue\n",
    "            \n",
    "            # 计算每日该时段的收益率\n",
    "            daily_returns = period_data.groupby(period_data.index.date).apply(\n",
    "                lambda x: np.log(x['close'].iloc[-1] / x['open'].iloc[0]) if len(x) > 0 else np.nan\n",
    "            )\n",
    "            \n",
    "            returns_data.append(pd.DataFrame({\n",
    "                'date': daily_returns.index,\n",
    "                'code': code,\n",
    "                'return': daily_returns.values\n",
    "            }))\n",
    "        \n",
    "        if returns_data:\n",
    "            result = pd.concat(returns_data, ignore_index=True)\n",
    "            return result.pivot(index='date', columns='code', values='return')\n",
    "        else:\n",
    "            return pd.DataFrame()\n",
    "    \n",
    "    def calculate_overnight_returns(self, data_dict: Dict[str, pd.DataFrame]) -> pd.DataFrame:\n",
    "        \"\"\"计算隔夜收益率\"\"\"\n",
    "        returns_data = []\n",
    "        \n",
    "        for code, df in data_dict.items():\n",
    "            # 获取每日开盘价和前日收盘价\n",
    "            daily_data = df.groupby(df.index.date).agg({\n",
    "                'open': 'first',\n",
    "                'close': 'last'\n",
    "            })\n",
    "            \n",
    "            # 计算隔夜收益率\n",
    "            overnight_returns = np.log(daily_data['open'] / daily_data['close'].shift(1))\n",
    "            \n",
    "            returns_data.append(pd.DataFrame({\n",
    "                'date': overnight_returns.index,\n",
    "                'code': code,\n",
    "                'return': overnight_returns.values\n",
    "            }))\n",
    "        \n",
    "        if returns_data:\n",
    "            result = pd.concat(returns_data, ignore_index=True)\n",
    "            return result.pivot(index='date', columns='code', values='return')\n",
    "        else:\n",
    "            return pd.DataFrame()\n",
    "    \n",
    "    def regression_residuals(self, stock_returns: pd.DataFrame, \n",
    "                           benchmark_returns: pd.Series) -> pd.Series:\n",
    "        \"\"\"计算回归残差\"\"\"\n",
    "        residuals = {}\n",
    "        \n",
    "        for stock in stock_returns.columns:\n",
    "            if stock in benchmark_returns.name:\n",
    "                continue\n",
    "                \n",
    "            # 对齐数据\n",
    "            stock_ret = stock_returns[stock].dropna()\n",
    "            bench_ret = benchmark_returns.reindex(stock_ret.index).dropna()\n",
    "            \n",
    "            # 确保数据对齐\n",
    "            common_idx = stock_ret.index.intersection(bench_ret.index)\n",
    "            if len(common_idx) < 10:  # 至少需要10个观测值\n",
    "                continue\n",
    "                \n",
    "            y = stock_ret.reindex(common_idx)\n",
    "            x = bench_ret.reindex(common_idx)\n",
    "            \n",
    "            # 线性回归\n",
    "            X = sm.add_constant(x)\n",
    "            try:\n",
    "                model = sm.OLS(y, X).fit()\n",
    "                residuals[stock] = model.resid\n",
    "            except:\n",
    "                continue\n",
    "        \n",
    "        return pd.DataFrame(residuals)\n",
    "    \n",
    "    def calculate_apm_stat(self, am_residuals: pd.DataFrame, \n",
    "                          pm_residuals: pd.DataFrame) -> pd.Series:\n",
    "        \"\"\"计算APM统计量\"\"\"\n",
    "        stats = {}\n",
    "        \n",
    "        common_stocks = am_residuals.columns.intersection(pm_residuals.columns)\n",
    "        \n",
    "        for stock in common_stocks:\n",
    "            am_resid = am_residuals[stock].dropna()\n",
    "            pm_resid = pm_residuals[stock].dropna()\n",
    "            \n",
    "            # 对齐数据\n",
    "            common_idx = am_resid.index.intersection(pm_resid.index)\n",
    "            if len(common_idx) < 10:\n",
    "                continue\n",
    "                \n",
    "            am_aligned = am_resid.reindex(common_idx)\n",
    "            pm_aligned = pm_resid.reindex(common_idx)\n",
    "            \n",
    "            # 计算差值\n",
    "            delta = am_aligned - pm_aligned\n",
    "            \n",
    "            # 计算统计量\n",
    "            if delta.std() > 0:\n",
    "                stat = (delta.mean() * np.sqrt(len(delta))) / delta.std()\n",
    "                stats[stock] = stat\n",
    "        \n",
    "        return pd.Series(stats)\n",
    "    \n",
    "    def neutralize_momentum(self, apm_stats: pd.Series, \n",
    "                          momentum_returns: pd.Series) -> pd.Series:\n",
    "        \"\"\"动量中性化\"\"\"\n",
    "        # 对齐数据\n",
    "        common_stocks = apm_stats.index.intersection(momentum_returns.index)\n",
    "        \n",
    "        if len(common_stocks) < 10:\n",
    "            return apm_stats\n",
    "        \n",
    "        y = apm_stats.reindex(common_stocks)\n",
    "        x = momentum_returns.reindex(common_stocks)\n",
    "        \n",
    "        # 去除缺失值\n",
    "        mask = ~(y.isna() | x.isna())\n",
    "        y_clean = y[mask]\n",
    "        x_clean = x[mask]\n",
    "        \n",
    "        if len(y_clean) < 10:\n",
    "            return apm_stats\n",
    "        \n",
    "        # 线性回归\n",
    "        try:\n",
    "            model = sm.OLS(y_clean, x_clean).fit()\n",
    "            residuals = model.resid\n",
    "            return residuals.reindex(apm_stats.index)\n",
    "        except:\n",
    "            return apm_stats"
   ]
