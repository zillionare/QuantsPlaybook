    "# 示例2: 批量因子分析\n",
    "def example_batch_analysis():\n",
    "    \"\"\"批量因子分析示例\"\"\"\n",
    "    \n",
    "    print(\"=== 批量APM因子分析示例 ===\")\n",
    "    print(\"注意: 这是一个计算密集的过程，可能需要较长时间\")\n",
    "    \n",
    "    # 设置参数（使用较短的时间范围和较少的股票数量）\n",
