    "# 批量因子计算和分析函数\n",
    "def batch_factor_analysis(index_code: str = '000905.XSHG',\n",
    "                         start_date: str = '20230101',\n",
    "                         end_date: str = '20231201',\n",
    "                         freq: str = 'M',  # 月度频率\n",
    "                         max_stocks: int = 100) -> Dict:\n",
    "    \"\"\"批量计算和分析APM因子\"\"\"\n",
    "    \n",
    "    # 生成交易日期序列\n",
    "    date_range = pd.date_range(start=start_date, end=end_date, freq=freq)\n",
    "    trade_dates = [d.strftime('%Y%m%d') for d in date_range]\n",
    "    \n",
    "    factor_types = ['apm_raw', 'apm_new', 'apm_1', 'apm_2', 'apm_3']\n",
    "    all_factors = {ft: {} for ft in factor_types}\n",
    "    all_returns = {}\n",
    "    ic_results = {ft: [] for ft in factor_types}\n",
    "    \n",
    "    benchmark = '000905.SH' if '000905' in index_code else '000300.SH'\n",
    "    \n",
    "    for trade_date in tqdm(trade_dates, desc='批量计算因子'):\n",
    "        try:\n",
    "            # 获取股票池\n",
    "            stocks = screener.get_filtered_stock_pool(index_code, trade_date)\n",
    "            if len(stocks) > max_stocks:\n",
    "                stocks = stocks[:max_stocks]  # 限制股票数量以提高计算效率\n",
    "            \n",
    "            if len(stocks) < 20:\n",
    "                continue\n",
    "            \n",
    "            # 计算各类型因子\n",
    "            for factor_type in factor_types:\n",
    "                try:\n",
    "                    factor = calculate_apm_factor(stocks, benchmark, trade_date, factor_type)\n",
    "                    if not factor.empty and len(factor) >= 10:\n",
    "                        all_factors[factor_type][trade_date] = factor\n",
    "                except Exception as e:\n",
    "                    print(f\"{trade_date} {factor_type}因子计算失败: {e}\")\n",
    "                    continue\n",
    "            \n",
    "            # 获取前瞻收益率\n",
    "            try:\n",
    "                forward_returns = analyzer.get_forward_returns(stocks, trade_date, 5)\n",
    "                if not forward_returns.empty:\n",
    "                    all_returns[trade_date] = forward_returns\n",
    "            except Exception as e:\n",
    "                print(f\"{trade_date}前瞻收益率计算失败: {e}\")\n",
    "                continue\n",
    "            \n",
    "            # 计算IC\n",
    "            if trade_date in all_returns:\n",
    "                for factor_type in factor_types:\n",
    "                    if trade_date in all_factors[factor_type]:\n",
    "                        ic_result = analyzer.calculate_ic(\n",
    "                            all_factors[factor_type][trade_date],\n",
    "                            all_returns[trade_date]\n",
    "                        )\n",
    "                        if ic_result:\n",
    "                            ic_result['date'] = trade_date\n",
    "                            ic_results[factor_type].append(ic_result)\n",
    "        \n",
    "        except Exception as e:\n",
    "            print(f\"{trade_date}整体计算失败: {e}\")\n",
    "            continue\n",
    "    \n",
    "    return {\n",
    "        'factors': all_factors,\n",
    "        'returns': all_returns,\n",
    "        'ic_results': ic_results\n",
    "    }\n",
    "\n",
    "def analyze_ic_performance(ic_results: Dict) -> pd.DataFrame:\n",
    "    \"\"\"分析IC表现\"\"\"\n",
    "    summary = []\n",
    "    \n",
    "    for factor_type, results in ic_results.items():\n",
    "        if not results:\n",
    "            continue\n",
    "            \n",
    "        df = pd.DataFrame(results)\n",
    "        \n",
    "        ic_mean = df['IC'].mean()\n",
    "        ic_std = df['IC'].std()\n",
    "        ic_ir = ic_mean / ic_std if ic_std > 0 else 0\n",
    "        \n",
    "        rank_ic_mean = df['Rank_IC'].mean()\n",
    "        rank_ic_std = df['Rank_IC'].std()\n",
    "        rank_ic_ir = rank_ic_mean / rank_ic_std if rank_ic_std > 0 else 0\n",
    "        \n",
    "        # 胜率\n",
    "        win_rate = (df['IC'] > 0).mean()\n",
    "        rank_win_rate = (df['Rank_IC'] > 0).mean()\n",
    "        \n",
    "        summary.append({\n",
    "            'Factor': factor_type,\n",
    "            'IC_Mean': ic_mean,\n",
    "            'IC_Std': ic_std,\n",
    "            'IC_IR': ic_ir,\n",
    "            'IC_WinRate': win_rate,\n",
    "            'RankIC_Mean': rank_ic_mean,\n",
    "            'RankIC_Std': rank_ic_std,\n",
    "            'RankIC_IR': rank_ic_ir,\n",
    "            'RankIC_WinRate': rank_win_rate,\n",
    "            'Sample_Count': len(df)\n",
    "        })\n",
    "    \n",
    "    return pd.DataFrame(summary)"
   ]
  },
