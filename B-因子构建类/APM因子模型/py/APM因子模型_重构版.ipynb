    "# 因子分析工具类\n",
    "class FactorAnalyzer:\n",
    "    \"\"\"因子分析器\"\"\"\n",
    "    \n",
    "    def __init__(self, data_provider: TuShareDataProvider):\n",
    "        self.data_provider = data_provider\n",
    "    \n",
    "    def get_forward_returns(self, stocks: List[str], factor_date: str, \n",
    "                           holding_period: int = 5) -> pd.Series:\n",
    "        \"\"\"获取前瞻收益率\"\"\"\n",
    "        start_date = factor_date\n",
    "        end_date = (pd.to_datetime(factor_date) + pd.Timedelta(days=holding_period*2)).strftime('%Y%m%d')\n",
    "        \n",
    "        returns = {}\n",
    "        for stock in tqdm(stocks, desc='获取前瞻收益率'):\n",
    "            try:\n",
    "                df = self.data_provider.get_daily_data(stock, start_date, end_date)\n",
    "                if len(df) >= holding_period:\n",
    "                    ret = (df['close'].iloc[holding_period-1] / df['close'].iloc[0]) - 1\n",
    "                    returns[stock] = ret\n",
    "            except:\n",
    "                continue\n",
    "            time.sleep(0.05)\n",
    "        \n",
    "        return pd.Series(returns)\n",
    "    \n",
    "    def calculate_ic(self, factor: pd.Series, returns: pd.Series) -> Dict:\n",
    "        \"\"\"计算IC指标\"\"\"\n",
    "        # 对齐数据\n",
    "        common_stocks = factor.index.intersection(returns.index)\n",
    "        factor_aligned = factor.reindex(common_stocks).dropna()\n",
    "        returns_aligned = returns.reindex(common_stocks).dropna()\n",
    "        \n",
    "        common_final = factor_aligned.index.intersection(returns_aligned.index)\n",
    "        \n",
    "        if len(common_final) < 10:\n",
    "            return {}\n",
    "        \n",
    "        f = factor_aligned.reindex(common_final)\n",
    "        r = returns_aligned.reindex(common_final)\n",
    "        \n",
    "        # 计算IC\n",
    "        ic = f.corr(r)\n",
    "        rank_ic = f.corr(r, method='spearman')\n",
    "        \n",
    "        # t检验\n",
    "        t_stat, p_value = stats.ttest_1samp([ic], 0)\n",
    "        \n",
    "        return {\n",
    "            'IC': ic,\n",
    "            'Rank_IC': rank_ic,\n",
    "            't_stat': t_stat[0] if hasattr(t_stat, '__len__') else t_stat,\n",
    "            'p_value': p_value[0] if hasattr(p_value, '__len__') else p_value,\n",
    "            'sample_size': len(common_final)\n",
    "        }\n",
    "    \n",
    "    def factor_quantile_analysis(self, factor: pd.Series, returns: pd.Series, \n",
    "                                quantiles: int = 5) -> pd.DataFrame:\n",
    "        \"\"\"因子分位数分析\"\"\"\n",
    "        # 对齐数据\n",
    "        common_stocks = factor.index.intersection(returns.index)\n",
    "        factor_aligned = factor.reindex(common_stocks).dropna()\n",
    "        returns_aligned = returns.reindex(common_stocks).dropna()\n",
    "        \n",
    "        common_final = factor_aligned.index.intersection(returns_aligned.index)\n",
    "        \n",
    "        if len(common_final) < quantiles * 2:\n",
    "            return pd.DataFrame()\n",
    "        \n",
    "        f = factor_aligned.reindex(common_final)\n",
    "        r = returns_aligned.reindex(common_final)\n",
    "        \n",
    "        # 分位数分组\n",
    "        quantile_labels = pd.qcut(f, quantiles, labels=False, duplicates='drop')\n",
    "        \n",
    "        # 计算各分位数收益率\n",
    "        results = []\n",
    "        for q in range(quantiles):\n",
    "            mask = quantile_labels == q\n",
    "            if mask.sum() > 0:\n",
    "                group_return = r[mask].mean()\n",
    "                group_count = mask.sum()\n",
    "                results.append({\n",
    "                    'quantile': q + 1,\n",
    "                    'return': group_return,\n",
    "                    'count': group_count\n",
    "                })\n",
    "        \n",
    "        return pd.DataFrame(results)\n",
    "    \n",
    "    def plot_quantile_returns(self, quantile_df: pd.DataFrame, title: str = 'Factor Quantile Returns'):\n",
    "        \"\"\"绘制分位数收益率图\"\"\"\n",
    "        if quantile_df.empty:\n",
    "            print(\"无数据可绘制\")\n",
    "            return\n",
    "        \n",
    "        plt.figure(figsize=(10, 6))\n",
    "        plt.bar(quantile_df['quantile'], quantile_df['return'])\n",
    "        plt.xlabel('因子分位数')\n",
    "        plt.ylabel('平均收益率')\n",
    "        plt.title(title)\n",
    "        plt.grid(True, alpha=0.3)\n",
    "        \n",
    "        # 添加数值标签\n",
    "        for i, v in enumerate(quantile_df['return']):\n",
    "            plt.text(quantile_df['quantile'].iloc[i], v + 0.001, f'{v:.3f}', \n",
    "                    ha='center', va='bottom')\n",
    "        \n",
    "        plt.tight_layout()\n",
    "        plt.show()\n",
    "\n",
    "# 初始化因子分析器\n",
    "analyzer = FactorAnalyzer(data_provider)"
   ]
  },
